# Application
APP_NAME=API
APP_VERSION=0.0.1

# Database
DB_CONFIG=postgresql+asyncpg://postgres:postgres@localhost:5432/app_db
DB_ECHO=false

# Logging
LOG_LEVEL=INFO

# Security / JWT
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=["http://localhost:5173", "http://localhost:8000"]
CORS_CREDENTIALS=true
CORS_METHODS=["*"]
CORS_HEADERS=["*"]
