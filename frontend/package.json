{
    "name": "strategic-diamond",
    "version": "0.0.1",
    "description": "Strategic Diamond",
    "main": "public/index.js",
    "module": "src/index.js",
    "scripts": {
        "scss": "sass --load-path=node_modules src/app/scss/assets.scss public/css/assets.css",
        "esbuild:base": "esbuild src/index.js --bundle --outfile=public/index.js --banner:js='/*! Page generated with CustomerJourney.js */'",
        "serve": "npm run esbuild:base -- --servedir=public",
        "init": "npm-run-all scss serve",
        "build": "npm run esbuild:base",
        "build:prod": "npm run esbuild:base -- --minify",
        "dev": "npm run esbuild:base -- --watch --serve-fallback=public/index.html --servedir=public"
    },
    "author": "Antonio Fregoso",
    "license": "GPL-3.0-or-later",
    "devDependencies": {
        "esbuild": "^0.25.5",
        "npm-run-all": "^4.1.5",
        "sass": "^1.71.1"
    },
    "dependencies": {
        "@carbon/charts": "^1.27.11",
        "redux-persist": "^6.0.0",
        "@reduxjs/toolkit": "^2.2.7",
        "animate.css": "^4.1.1",
        "bulma": "^1.0.2",
        "@fortawesome/fontawesome-svg-core": "^6.5.2",
        "@fortawesome/free-brands-svg-icons": "^6.5.2",
        "@fortawesome/free-regular-svg-icons": "^6.5.2",
        "@fortawesome/free-solid-svg-icons": "^6.5.2"
    }
}